{
  "name": "@reearth/cms-api",
  "version": "0.2.0",
  "description": "Re:Earth CMS Integration API client for TypeScript/JavaScript. Works on Cloudflare Workers, Node.js 18+, Bun, and Deno.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/reearth/reearth-cms-api.git",
    "directory": "ts"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhook": {
      "types": "./dist/webhook.d.ts",
      "import": "./dist/webhook.js",
      "require": "./dist/webhook.cjs"
    },
    "./public": {
      "types": "./dist/public.d.ts",
      "import": "./dist/public.js",
      "require": "./dist/public.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "openapi-typescript ../schemas/integration.yml -o ./src/generated/schema.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepack": "npm run build",
    "prepublishOnly": "npm run format:check && npm run typecheck && npm test"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openapi-typescript": "^7.4.0",
    "prettier": "^3.8.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
